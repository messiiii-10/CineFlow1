@model CineFlow.Models.ViewModels.IcerikDetayViewModel
@using Microsoft.AspNetCore.Http
@using System.Linq

@{
    var currentUser = Context.Session.GetString("User");
    var canTrack = Model.KutuphaneEtkilesimiAcik;
    var item = Model.Icerik;
    var hasPoster = !string.IsNullOrWhiteSpace(item.GorselKaynak);
    var hasBanner = !string.IsNullOrWhiteSpace(item.BannerKaynak);
}

<div class="page-intro mt-4">
    <a href="/" class="back-link"><i class="bi bi-arrow-left"></i> Kataloğa dön</a>
</div>

<section class="wiki-hero mt-3" style="@(hasBanner ? $"background-image: linear-gradient(120deg, rgba(8,10,17,.78), rgba(8,10,17,.92)), url('{item.BannerKaynak}');" : "")">
    <div>
        <div class="meta-row mb-3">
            <span class="soft-badge">@item.TurEtiketi</span>
            <span class="soft-badge">@item.FormatEtiketi</span>
            <span class="soft-badge">@item.DurumEtiketi</span>
        </div>
        <h1>@item.Baslik</h1>
        @if (!string.IsNullOrWhiteSpace(item.AlternatifBaslik) || !string.IsNullOrWhiteSpace(item.OrijinalBaslik))
        {
            <p class="wiki-subtitle">@item.AlternatifBaslik @(!string.IsNullOrWhiteSpace(item.AlternatifBaslik) && !string.IsNullOrWhiteSpace(item.OrijinalBaslik) ? "•" : "") @item.OrijinalBaslik</p>
        }
        <p class="lead-copy mb-0">Popülerlik, yapım bilgisi, karakterler ve tür etiketleriyle zenginleştirilmiş detay sayfası.</p>
    </div>
</section>

<section class="detail-shell mt-4">
    <div>
        @if (hasPoster)
        {
            <div class="media-frame media-frame--detail" data-media-frame>
                <img src="@item.GorselKaynak" alt="@item.Baslik afişi" class="detail-poster media-frame__image" data-fallback-image />
                <div class="detail-placeholder media-frame__fallback" data-media-fallback hidden>
                    <span>@item.TurEtiketi</span>
                </div>
            </div>
        }
        else
        {
            <div class="detail-placeholder">
                <span>@item.TurEtiketi</span>
            </div>
        }
    </div>

    <div class="surface-panel detail-copy">
        <div class="wiki-section">
            <div class="eyebrow">Özet</div>
            <p class="detail-description">@item.Aciklama</p>
        </div>

        <div class="wiki-summary-grid">
            <div>
                <span class="stat-label">Skor</span>
                <strong>@item.SkorEtiketi</strong>
            </div>
            <div>
                <span class="stat-label">Topluluk Puanı</span>
                <strong>@(Model.OrtalamaKullaniciPuani.HasValue ? $"{Model.OrtalamaKullaniciPuani.Value:F1}/10" : "-")</strong>
            </div>
            <div>
                <span class="stat-label">Popülerlik</span>
                <strong>@item.PopulerlikEtiketi</strong>
            </div>
            <div>
                <span class="stat-label">Dönem</span>
                <strong>@item.DonemEtiketi</strong>
            </div>
            <div>
                <span class="stat-label">Yorum</span>
                <strong>@item.Yorumlar.Count</strong>
            </div>
            <div>
                <span class="stat-label">Puanlayan</span>
                <strong>@Model.PuanlayanKullaniciSayisi</strong>
            </div>
        </div>

        <div class="wiki-infobox mt-4">
            <div><span>Tür</span><strong>@item.TurEtiketi</strong></div>
            <div><span>Format</span><strong>@item.FormatEtiketi</strong></div>
            <div><span>Durum</span><strong>@item.DurumEtiketi</strong></div>
            <div><span>Kaynak</span><strong>@item.KaynakEtiketi</strong></div>
            <div><span>Stüdyo / Yayıncı</span><strong>@(string.IsNullOrWhiteSpace(item.Studyo) ? "Bilinmiyor" : item.Studyo)</strong></div>
            <div><span>Yaratıcılar</span><strong>@(string.IsNullOrWhiteSpace(item.Yaraticilar) ? "Bilinmiyor" : item.Yaraticilar)</strong></div>
            <div><span>Episode / Chapter</span><strong>@(item.BolumSayisi?.ToString() ?? "Bilinmiyor")</strong></div>
            <div><span>Volume</span><strong>@(item.CiltSayisi?.ToString() ?? "-")</strong></div>
            <div><span>Süre</span><strong>@(item.SureDakika is null ? "-" : $"{item.SureDakika} dk")</strong></div>
        </div>

        @if (item.KategoriListesi.Count > 0)
        {
            <div class="wiki-section mt-4">
                <div class="eyebrow">Kategoriler</div>
                <div class="tag-cloud">
                    @foreach (var kategori in item.KategoriListesi)
                    {
                        <span class="soft-badge">@kategori</span>
                    }
                </div>
            </div>
        }

        @if (item.EtiketListesi.Count > 0)
        {
            <div class="wiki-section mt-4">
                <div class="eyebrow">Öne Çıkan Etiketler</div>
                <div class="tag-cloud">
                    @foreach (var etiket in item.EtiketListesi)
                    {
                        <span class="soft-badge soft-badge--dark">@etiket</span>
                    }
                </div>
            </div>
        }

        @if (item.KarakterListesi.Count > 0)
        {
            <div class="wiki-section mt-4">
                <div class="eyebrow">Ana Karakterler</div>
                <div class="character-list">
                    @foreach (var karakter in item.KarakterListesi)
                    {
                        <span>@karakter</span>
                    }
                </div>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(item.DisBaglanti))
        {
            <div class="mt-4">
                <a href="@item.DisBaglanti" target="_blank" rel="noreferrer" class="btn btn-outline-dark rounded-pill px-4">Harici Kaynağı Aç</a>
            </div>
        }
    </div>
</section>

<section class="surface-panel mt-4">
    <div class="section-heading mb-4">
        <div>
            <div class="eyebrow">Kişisel Takip</div>
            <h2>İzleme ve Puanlama</h2>
        </div>
        <p>İçeriği profiline ekle, durumunu güncelle ve puanını ver.</p>
    </div>

    @if (TempData["CollectionMessage"] is string collectionMessage)
    {
        <div class="alert alert-success">@collectionMessage</div>
    }

    @if (TempData["CollectionError"] is string collectionError)
    {
        <div class="alert alert-danger">@collectionError</div>
    }

    @if (canTrack)
    {
        <form asp-action="KutuphaneGuncelle" method="post" class="library-form">
            <input type="hidden" name="icerikId" value="@item.Id" />

            <div class="library-form__grid">
                <div>
                    <label class="form-label">Durum</label>
                    <select name="durum" class="form-select">
                        <option value="@((int)KullaniciIcerikDurumu.Planliyor)" selected="@(Model.KullaniciKaydi?.Durum == KullaniciIcerikDurumu.Planliyor ? "selected" : null)">Listemde</option>
                        <option value="@((int)KullaniciIcerikDurumu.Izliyor)" selected="@(Model.KullaniciKaydi?.Durum == KullaniciIcerikDurumu.Izliyor ? "selected" : null)">İzliyorum</option>
                        <option value="@((int)KullaniciIcerikDurumu.Tamamlandi)" selected="@(Model.KullaniciKaydi?.Durum == KullaniciIcerikDurumu.Tamamlandi ? "selected" : null)">Tamamladım</option>
                        <option value="@((int)KullaniciIcerikDurumu.Birakti)" selected="@(Model.KullaniciKaydi?.Durum == KullaniciIcerikDurumu.Birakti ? "selected" : null)">Bıraktım</option>
                    </select>
                </div>
                <div>
                    <label class="form-label">Kişisel Puanın</label>
                    <select name="kisiselPuan" class="form-select">
                        <option value="">Puan verme</option>
                        @for (var score = 1; score <= 10; score++)
                        {
                            <option value="@score" selected="@(Model.KullaniciKaydi?.KisiselPuan == score ? "selected" : null)">@score / 10</option>
                        }
                    </select>
                </div>
            </div>

            <div class="library-form__actions">
                <button type="submit" class="btn btn-dark rounded-pill px-4">İzleme Listesini Güncelle</button>
            </div>
        </form>

        <form asp-action="FavoriDurumunuDegistir" method="post" class="library-form__remove">
            <input type="hidden" name="icerikId" value="@item.Id" />
            <input type="hidden" name="favoriMi" value="@(Model.KullaniciKaydi?.FavoriMi == true ? "false" : "true")" />
            <button type="submit" class="btn btn-outline-dark rounded-pill px-4">
                @(Model.KullaniciKaydi?.FavoriMi == true ? "Favoriden Çıkar" : "Favorilere Ekle")
            </button>
        </form>

        @if (Model.KullaniciKaydi?.KutuphanedeMi == true)
        {
            <form asp-action="KutuphaneKaydiniSil" method="post" class="library-form__remove">
                <input type="hidden" name="icerikId" value="@item.Id" />
                <button type="submit" class="btn btn-outline-dark rounded-pill px-4">İzleme Listesinden Kaldır</button>
            </form>
        }
    }
    else
    {
        <div class="alert alert-warning mb-0">
            İçeriği profilinde takip etmek ve puan vermek için <a href="/Home/Login">giriş yap</a>.
        </div>
    }
</section>

<section class="surface-panel mt-4">
    <div class="section-heading mb-4">
        <div>
            <div class="eyebrow">Topluluk</div>
            <h2>Yorumlar</h2>
        </div>
        <p>İçeriğe dair düşüncelerini burada paylaşabilirsin.</p>
    </div>

    @if (TempData["CommentError"] is string errorMessage)
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(currentUser))
    {
        <form asp-action="YorumYap" method="post" class="comment-form">
            <input type="hidden" name="icerikId" value="@item.Id" />
            <label class="form-label">Yorumun</label>
            <textarea name="mesaj" class="form-control form-control-lg mb-3" rows="4" maxlength="500" placeholder="Bu içerik hakkında ne düşünüyorsun?" required></textarea>
            <button class="btn btn-dark rounded-pill px-4" type="submit">Yorumu Gönder</button>
        </form>
    }
    else
    {
        <div class="alert alert-warning mb-4">
            Yorum yapabilmek için <a href="/Home/Login">giriş yap</a> veya <a href="/Home/Kayit">hesap oluştur</a>.
        </div>
    }

    @if (Model.Yorumlar.Count == 0)
    {
        <div class="empty-state">
            <h3>Henüz yorum yok</h3>
            <p>İlk görüşü paylaşan kullanıcı sen olabilirsin.</p>
        </div>
    }
    else
    {
        <div class="comment-list">
            @foreach (var y in Model.Yorumlar)
            {
                <article class="comment-card">
                    <div class="comment-card__head">
                        <div class="comment-card__identity">
                            @if (!string.IsNullOrWhiteSpace(y.ProfilResmiKaynak))
                            {
                                <img src="@y.ProfilResmiKaynak" alt="@y.KullaniciAdi profil resmi" class="comment-card__avatar comment-card__avatar--image" />
                            }
                            else
                            {
                                <div class="comment-card__avatar">@y.Monogram</div>
                            }
                            <strong>@y.KullaniciAdi</strong>
                        </div>
                        <span>@y.Tarih.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
                    </div>
                    <p>@y.Mesaj</p>
                </article>
            }
        </div>
    }
</section>

@if (Model.BenzerIcerikler.Count > 0)
{
    <section class="mt-4">
        <div class="section-heading mb-3">
            <div>
                <div class="eyebrow">Benzer İçerikler</div>
                <h2>Aynı evrende gezmeye devam et</h2>
            </div>
        </div>
        <div class="related-grid">
            @foreach (var benzer in Model.BenzerIcerikler)
            {
                <a class="related-card" href="/Home/Detay/@benzer.Id">
                    @if (!string.IsNullOrWhiteSpace(benzer.GorselKaynak))
                    {
                        <div class="media-frame" data-media-frame>
                            <img src="@benzer.GorselKaynak" alt="@benzer.Baslik" class="media-frame__image" data-fallback-image />
                            <div class="profile-library__placeholder media-frame__fallback" data-media-fallback hidden>@benzer.TurEtiketi</div>
                        </div>
                    }
                    else
                    {
                        <div class="profile-library__placeholder">@benzer.TurEtiketi</div>
                    }
                    <div>
                        <strong>@benzer.Baslik</strong>
                        <span>@benzer.FormatEtiketi • @benzer.SkorEtiketi</span>
                    </div>
                </a>
            }
        </div>
    </section>
}
