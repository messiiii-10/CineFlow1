@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CineFlow</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Source+Serif+4:wght@600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="app-shell">
    @{
        var adminEmail = Context.Session.GetString("AdminEmail");
        var isAdmin = Context.Session.GetString("AdminAuth") == "true";
        var currentUser = Context.Session.GetString("User");
    }
    <header>
        <nav class="navbar navbar-expand-lg app-nav">
            <div class="container">
                <a class="navbar-brand brand-mark" href="/">
                    <span class="brand-mark__glyph">CF</span>
                    <span>CineFlow</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Menüyü aç">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto mb-3 mb-lg-0 nav-pills-custom">
                        <li class="nav-item"><a class="nav-link" href="/">Katalog</a></li>
                        @if (isAdmin)
                        {
                            <li class="nav-item"><a class="nav-link" href="/Admin/Index">Yönetim</a></li>
                        }
                    </ul>

                    <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2">
                        @if (isAdmin)
                        {
                            <li class="nav-item">
                                <span class="chip chip-danger"><i class="bi bi-shield-lock me-1"></i>@adminEmail</span>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-sm btn-outline-light rounded-pill px-3" href="/Admin/Index">Panel</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-sm btn-accent rounded-pill px-3" href="/Admin/Logout">Çıkış</a>
                            </li>
                        }
                        else if (!string.IsNullOrWhiteSpace(currentUser))
                        {
                            <li class="nav-item">
                                <span class="chip"><i class="bi bi-person-circle me-1"></i>@currentUser</span>
                            </li>
                            <li class="nav-item">
                               <a class="btn btn-sm btn-outline-light rounded-pill px-3" href="/Home/Logout">Çıkış Yap</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="/Home/Login">Giriş Yap</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-sm btn-light rounded-pill px-3" href="/Home/Kayit">Kayıt Ol</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-sm btn-outline-light rounded-pill px-3" href="/Admin/Login">Admin</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container pb-5">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-note">
        <div class="container d-flex flex-column flex-md-row justify-content-between gap-2">
            <span>CineFlow katalog, yorum ve yönetim akışını tek bir panelde toplar.</span>
            <span class="text-md-end">ASP.NET Core MVC demo uygulaması</span>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
